            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/elephant.spell.SuggestionsResponse"
                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Suggestions",
        "tags": [
          "Check"
