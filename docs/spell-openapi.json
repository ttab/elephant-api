{
  "components": {
    "schemas": {
      "elephant.spell.CorrectionLevel": {
        "enum": [
          "LEVEL_UNSPECIFIED",
          "LEVEL_ERROR",
          "LEVEL_SUGGESTION"
        ],
        "type": "string"
      },
      "elephant.spell.CustomDictionary": {
        "properties": {
          "entry_count": {
            "description": "EntryCount for the dictionary.",
            "type": "integer"
          },
          "language": {
            "description": "Language the dictionary is for.",
            "type": "string"
          },
          "pending_count": {
            "description": "PendingCount is the number of entries awaiting moderation.",
            "type": "integer"
          },
          "rule_count": {
            "description": "RuleCount is the number of pattern rules for the language.",
            "type": "integer"
          },
          "rule_pending_count": {
            "description": "RulePendingCount is the number of rules awaiting moderation.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "elephant.spell.CustomEntry": {
        "properties": {
          "case_sensitive": {
            "description": "CaseSensitive controls whether the entry only matches with the exact casing of its text and common mistakes. Defaults to false (case-insensitive matching), which suits ordinary words; proper nouns should set it to true.",
            "type": "boolean"
          },
          "common_mistakes": {
            "description": "CommonMistakes when writing the word or phrase. This is used to pre-filter text that is spell-checked.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "description": {
            "description": "Description of the entry.",
            "type": "string"
          },
          "forms": {
            "additionalProperties": {
              "type": "string"
            },
            "description": "Forms is an alternative to the common mistakes -\u003e text pairing and allows the mapping of different forms of the word or phrase to specific replacements.",
            "type": "object"
          },
          "language": {
            "description": "Language the entry is for.",
            "type": "string"
          },
          "level": {
            "$ref": "#/components/schemas/elephant.spell.CorrectionLevel"
          },
          "status": {
            "description": "Status of the entry, this is used for moderation.",
            "type": "string"
          },
          "text": {
            "description": "Text is the word (or phrase) itself.",
            "type": "string"
          },
          "updated": {
            "description": "Updated is the last update time in RFC3339 format.",
            "type": "string"
          },
          "updated_by": {
            "description": "UpdatedBy is the identity of the party that last updated the entry.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.DeleteEntryRequest": {
        "properties": {
          "language": {
            "description": "Language the entry is for.",
            "type": "string"
          },
          "text": {
            "description": "Text is the word or phrase to delete.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.DeleteEntryResponse": {
        "type": "object"
      },
      "elephant.spell.DeleteRuleRequest": {
        "properties": {
          "id": {
            "description": "ID of the rule to delete.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "elephant.spell.DeleteRuleResponse": {
        "type": "object"
      },
      "elephant.spell.GetEntryRequest": {
        "properties": {
          "language": {
            "description": "Language the entry is for.",
            "type": "string"
          },
          "text": {
            "description": "Text is the word or phrase to get the entry for.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.GetEntryResponse": {
        "properties": {
          "entry": {
            "$ref": "#/components/schemas/elephant.spell.CustomEntry"
          }
        },
        "type": "object"
      },
      "elephant.spell.GetRuleRequest": {
        "properties": {
          "id": {
            "description": "ID of the rule to get.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "elephant.spell.GetRuleResponse": {
        "properties": {
          "rule": {
            "$ref": "#/components/schemas/elephant.spell.Rule"
          }
        },
        "type": "object"
      },
      "elephant.spell.Language": {
        "properties": {
          "code": {
            "description": "Code for the language.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.ListDictionariesRequest": {
        "type": "object"
      },
      "elephant.spell.ListDictionariesResponse": {
        "properties": {
          "dictionaries": {
            "items": {
              "$ref": "#/components/schemas/elephant.spell.CustomDictionary"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "elephant.spell.ListEntriesRequest": {
        "properties": {
          "language": {
            "description": "Language to list entries for.",
            "type": "string"
          },
          "page": {
            "description": "Page to return.",
            "type": "integer"
          },
          "page_size": {
            "description": "PageSize is the number of entries to return per page. Optional, defaults to 100 when zero.",
            "type": "integer"
          },
          "query": {
            "description": "Query filters entries by a free-text substring, matched against the entry text, its description, and its common mistakes.",
            "type": "string"
          },
          "status": {
            "description": "Status to filter entries by",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.ListEntriesResponse": {
        "properties": {
          "entries": {
            "items": {
              "$ref": "#/components/schemas/elephant.spell.CustomEntry"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "elephant.spell.ListRulesRequest": {
        "properties": {
          "language": {
            "description": "Language to list rules for.",
            "type": "string"
          },
          "page": {
            "description": "Page to return.",
            "type": "integer"
          },
          "page_size": {
            "description": "PageSize is the number of rules per page. Optional, defaults to 100.",
            "type": "integer"
          },
          "query": {
            "description": "Query filters rules by a free-text substring, matched against the name, description, pattern and replacement.",
            "type": "string"
          },
          "status": {
            "description": "Status to filter rules by.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.ListRulesResponse": {
        "properties": {
          "rules": {
            "items": {
              "$ref": "#/components/schemas/elephant.spell.Rule"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "elephant.spell.Misspelled": {
        "properties": {
          "entries": {
            "items": {
              "$ref": "#/components/schemas/elephant.spell.MisspelledEntry"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "elephant.spell.MisspelledEntry": {
        "properties": {
          "level": {
            "$ref": "#/components/schemas/elephant.spell.CorrectionLevel"
          },
          "status": {
            "description": "Status of the custom entry the correction is based on, e.g. \"accepted\" or \"pending\". Empty for corrections that don't originate from a custom entry (such as plain hunspell results). Clients can use this to indicate that a correction comes from an unreviewed (pending) entry.",
            "type": "string"
          },
          "suggestions": {
            "description": "Suggestions for replacements.",
            "items": {
              "$ref": "#/components/schemas/elephant.spell.Suggestion"
            },
            "type": "array"
          },
          "text": {
            "description": "Text that was used in the source text.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.Rule": {
        "description": "Rule is a named token-pattern matcher. The pattern uses a small DSL: literals match tokens case-insensitively, \":digit\" matches a number, \":word\" matches a word, and \":gap\" / \":gap(N)\" match up to N intervening words. Capturing tokens (classes and gaps) are referenced in the replacement template as {1}, {2}, … in order. For example pattern \":digit - :digit\" with replacement \"{1}–{2}\" turns \"12-15\" into \"12–15\".",
        "properties": {
          "after": {
            "description": "After, when set, requires one of these tokens immediately after a match.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "before": {
            "description": "Before, when set, requires one of these tokens immediately before a match.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "description": {
            "description": "Description shown to editors as context for the correction.",
            "type": "string"
          },
          "id": {
            "description": "ID is the sequential primary key of the rule. Zero when creating a new rule; the server assigns it.",
            "type": "integer"
          },
          "language": {
            "description": "Language the rule is for.",
            "type": "string"
          },
          "level": {
            "$ref": "#/components/schemas/elephant.spell.CorrectionLevel"
          },
          "name": {
            "description": "Name is a human-readable label for the rule. It is not unique.",
            "type": "string"
          },
          "not_after": {
            "description": "NotAfter suppresses the match when followed by one of these tokens.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "not_before": {
            "description": "NotBefore suppresses the match when preceded by one of these tokens.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "pattern": {
            "description": "Pattern to match, in the rule DSL.",
            "type": "string"
          },
          "replacement": {
            "description": "Replacement template for the suggestion.",
            "type": "string"
          },
          "status": {
            "description": "Status of the rule, used for moderation.",
            "type": "string"
          },
          "updated": {
            "description": "Updated is the last update time in RFC3339 format.",
            "type": "string"
          },
          "updated_by": {
            "description": "UpdatedBy is the identity of the party that last updated the rule.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.SetEntryRequest": {
        "properties": {
          "entry": {
            "$ref": "#/components/schemas/elephant.spell.CustomEntry"
          }
        },
        "type": "object"
      },
      "elephant.spell.SetEntryResponse": {
        "type": "object"
      },
      "elephant.spell.SetEntryStatusRequest": {
        "properties": {
          "language": {
            "description": "Language the entry is for.",
            "type": "string"
          },
          "status": {
            "description": "Status to set, e.g. \"accepted\" or \"pending\".",
            "type": "string"
          },
          "text": {
