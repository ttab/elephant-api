        "type": "object"
      },
      "elephant.spell.SetRuleStatusRequest": {
        "properties": {
          "id": {
            "description": "ID of the rule to update.",
            "type": "integer"
          },
          "status": {
            "description": "Status to set, e.g. \"accepted\" or \"pending\".",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.SetRuleStatusResponse": {
        "type": "object"
      },
      "elephant.spell.Suggestion": {
        "properties": {
          "description": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.SuggestionsRequest": {
        "properties": {
          "custom_only": {
            "description": "CustomOnly limits suggestions to the custom dictionary, skipping the hunspell pass.",
            "type": "boolean"
          },
          "language": {
            "description": "Language to get suggestions in.",
            "type": "string"
          },
          "text": {
            "description": "Text is the word or phrase to get suggestions for.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.spell.SuggestionsResponse": {
        "properties": {
          "suggestions": {
            "description": "Suggestions for replacements.",
            "items": {
              "$ref": "#/components/schemas/elephant.spell.Suggestion"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "elephant.spell.SupportedLanguagesRequest": {
        "type": "object"
      },
      "elephant.spell.SupportedLanguagesResponse": {
        "properties": {
          "languages": {
            "description": "Languages that can be used for spellchecking.",
            "items": {
              "$ref": "#/components/schemas/elephant.spell.Language"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "elephant.spell.TextRequest": {
        "properties": {
          "custom_only": {
            "description": "CustomOnly limits checks to the custom dictionary, skipping the hunspell pass. Useful when you only want to surface custom writing rules without the noise of hunspell corrections.",
            "type": "boolean"
          },
          "language": {
            "description": "Language to check the text for.",
            "type": "string"
          },
          "suggestions": {
            "description": "Suggestions enables generation of suggestions for misspelled words. In interactive applications this should normally be done by calling the Suggestions method on demand.",
            "type": "boolean"
          },
          "text": {
            "description": "Text to spellcheck.",
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "elephant.spell.TextResponse": {
        "properties": {
          "misspelled": {
            "items": {
              "$ref": "#/components/schemas/elephant.spell.Misspelled"
            },
            "type": "array"
          }
        },
        "type": "object"
      }
    },
    "securitySchemes": {
      "bearer": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
