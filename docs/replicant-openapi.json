{
  "components": {
    "schemas": {
      "elephant.replicant.AttachmentForType": {
        "description": "AttachmentForType identifies an attachment to include for a specific document type. Format in environment variable: \"name.type\", e.g. \"image.core/image\".",
        "properties": {
          "name": {
            "description": "The document type, e.g. \"core/image\".",
            "type": "string"
          },
          "type": {
            "description": "The attachment name, e.g. \"image\".",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.replicant.ChangeTargetStateRequest": {
        "properties": {
          "action": {
            "$ref": "#/components/schemas/elephant.replicant.TargetAction"
          },
          "name": {
            "description": "Name of the replication target.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.replicant.ChangeTargetStateResponse": {
        "type": "object"
      },
      "elephant.replicant.ConfigureTargetRequest": {
        "description": "ConfigureTargetRequest creates or updates a replication target.",
        "properties": {
          "client_id": {
            "description": "The OAuth2 client ID for target authentication.",
            "type": "string"
          },
          "client_secret": {
            "description": "The OAuth2 client secret for target authentication.",
            "type": "string"
          },
          "config": {
            "$ref": "#/components/schemas/elephant.replicant.SyncConfig"
          },
          "name": {
            "description": "Name is the identifier for the replication target.",
            "type": "string"
          },
          "oidc_config": {
            "description": "The OIDC discovery configuration URL for target authentication.",
            "type": "string"
          },
          "repository_url": {
            "description": "The URL of the target repository to replicate to.",
            "type": "string"
          },
          "start_from": {
            "description": "The event log position to start replication from.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "elephant.replicant.ConfigureTargetResponse": {
        "type": "object"
      },
      "elephant.replicant.GetTargetStateRequest": {
        "properties": {
          "name": {
            "description": "Name of the replication target.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.replicant.GetTargetStateResponse": {
        "properties": {
          "state": {
            "$ref": "#/components/schemas/elephant.replicant.TargetState"
          }
        },
        "type": "object"
      },
      "elephant.replicant.RemoveTargetRequest": {
        "properties": {
          "name": {
            "description": "Name of the replication target to remove.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.replicant.RemoveTargetResponse": {
        "type": "object"
      },
      "elephant.replicant.SectionForType": {
        "description": "SectionForType identifies a section to ignore for a specific document type.",
        "properties": {
          "section_uuid": {
            "description": "The UUID of the section to ignore.",
            "type": "string"
          },
          "type": {
            "description": "The document type, e.g. \"core/event\".",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.replicant.SendDocumentRequest": {
        "properties": {
          "force": {
            "description": "Force replication even if the document has already been replicated.",
            "type": "boolean"
          },
          "uuid": {
            "description": "The UUID of the document to replicate.",
            "type": "string"
          }
        },
        "type": "object"
      },
      "elephant.replicant.SendDocumentResponse": {
        "properties": {
          "target_version": {
            "description": "The version of the document that was replicated to the target.",
            "type": "integer"
          }
        },
        "type": "object"
      },
      "elephant.replicant.SyncConfig": {
        "description": "SyncConfig controls what documents and content are replicated.",
        "properties": {
          "accept_errors": {
            "description": "Accept and skip documents that fail to replicate instead of blocking.",
            "type": "boolean"
          },
          "all_attachments": {
            "description": "Replicate all attachments for documents.",
            "type": "boolean"
          },
          "ignore_sections": {
            "description": "Sections to exclude from replication, identified by document type and section UUID.",
            "items": {
              "$ref": "#/components/schemas/elephant.replicant.SectionForType"
            },
            "type": "array"
          },
          "ignore_subs": {
            "description": "Ignore events generated by these client subs.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "ignore_types": {
            "description": "Document types to exclude from replication.",
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "include_attachments": {
            "description": "Specific attachments to include when all_attachments is false.",
            "items": {
              "$ref": "#/components/schemas/elephant.replicant.AttachmentForType"
            },
            "type": "array"
          }
        },
        "type": "object"
      },
      "elephant.replicant.TargetAction": {
        "description": "TargetAction is the action to take on a replication target.",
        "enum": [
          "TARGET_ACTION_UNSPECIFIED",
          "TARGET_ACTION_START",
          "TARGET_ACTION_STOP"
        ],
        "type": "string"
      },
      "elephant.replicant.TargetState": {
        "description": "TargetState describes the current runtime state of a replication target.",
        "enum": [
          "TARGET_STATE_UNSPECIFIED",
          "TARGET_STATE_RUNNING",
          "TARGET_STATE_STARTING",
          "TARGET_STATE_STOPPING",
          "TARGET_STATE_STOPPED"
        ],
        "type": "string"
      }
    },
    "securitySchemes": {
      "bearer": {
        "bearerFormat": "JWT",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "title": "replicant API",
    "version": "v0.21.3"
  },
  "openapi": "3.0.0",
  "paths": {
    "/twirp/elephant.replicant.Replication/ChangeTargetState": {
      "post": {
        "description": "ChangeTargetState starts or stops a replication target.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/elephant.replicant.ChangeTargetStateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/elephant.replicant.ChangeTargetStateResponse"
                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "ChangeTargetState",
        "tags": [
          "Replication"
        ]
      }
    },
    "/twirp/elephant.replicant.Replication/ConfigureTarget": {
      "post": {
        "description": "ConfigureTarget creates or updates a replication target. The configuration maps to the environment variables used for static configuration in elephant-replicant.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/elephant.replicant.ConfigureTargetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/elephant.replicant.ConfigureTargetResponse"
                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "ConfigureTarget",
        "tags": [
          "Replication"
        ]
      }
    },
    "/twirp/elephant.replicant.Replication/GetTargetState": {
      "post": {
        "description": "GetTargetState returns the current state of a replication target.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/elephant.replicant.GetTargetStateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/elephant.replicant.GetTargetStateResponse"
                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "GetTargetState",
        "tags": [
          "Replication"
        ]
      }
    },
    "/twirp/elephant.replicant.Replication/RemoveTarget": {
      "post": {
        "description": "RemoveTarget deletes a replication target and stops its replication.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/elephant.replicant.RemoveTargetRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/elephant.replicant.RemoveTargetResponse"
                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "RemoveTarget",
        "tags": [
          "Replication"
        ]
      }
    },
    "/twirp/elephant.replicant.Replication/SendDocument": {
      "post": {
        "description": "SendDocument triggers replication of a single document by UUID.",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/elephant.replicant.SendDocumentRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/elephant.replicant.SendDocumentResponse"
                }
              }
            },
            "description": "Method response"
          },
          "default": {
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "SendDocument",
        "tags": [
          "Replication"
        ]
      }
    }
  },
  "servers": [
    {
      "url": "https://replicant.api.tt.se"
